{
  "manifest_version": 3,
  "name": "LinkedIn Scraper",
  "version": "1.0",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}